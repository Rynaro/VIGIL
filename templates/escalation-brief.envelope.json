{
  "envelope_version": "1.0",
  "message_id": "{{ message_id }}",
  "thread_id": "{{ thread_id }}",
  "parent_id": "{{ parent_id }}",
  "from": {
    "eidolon": "vigil",
    "version": "1.6.0"
  },
  "to": {
    "eidolon": "forge",
    "version": "{{ to.version }}"
  },
  "performative": "ESCALATE",
  "edge_origin": "roster",
  "objective": "{{ objective }}",
  "artifact": {
    "kind": "escalation-brief",
    "schema_version": "1.0",
    "path": "{{ artifact.path }}",
    "sha256": "{{ artifact.sha256 }}",
    "size_bytes": "{{ artifact.size_bytes }}"
  },
  "context_delta": {
    "token_budget": 4000,
    "tokens_used": "{{ context_delta.tokens_used }}",
    "input_handles": [
      "{{ context_delta.input_handles[0] }}",
      "{{ context_delta.input_handles[1] }}"
    ],
    "summary": "{{ context_delta.summary }}"
  },
  "constraints": {
    "trust_level": "standard"
  },
  "expected_response": {
    "performative": "PROPOSE",
    "shape_hint": "reasoning-report with ranked hypotheses and recommended investigation path"
  },
  "confidence": "{{ confidence }}",
  "assumptions": [
    "trigger: budget-exhausted-no-flip",
    "{{ assumptions[1] }}"
  ],
  "integrity": {
    "method": "sha256",
    "value": "{{ integrity.value }}"
  },
  "trace": {
    "ts": "{{ trace.ts }}",
    "host": "{{ trace.host }}",
    "model": "{{ trace.model }}",
    "tier": "standard"
  }
}
