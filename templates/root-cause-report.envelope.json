{
  "envelope_version": "1.0",
  "message_id": "{{ message_id }}",
  "thread_id": "{{ thread_id }}",
  "parent_id": "{{ parent_id }}",
  "from": {
    "eidolon": "vigil",
    "version": "1.7.0"
  },
  "to": {
    "eidolon": "{{ to.eidolon }}",
    "version": "{{ to.version }}"
  },
  "performative": "{{ performative }}",
  "edge_origin": "roster",
  "objective": "{{ objective }}",
  "artifact": {
    "kind": "root-cause-report",
    "schema_version": "1.0",
    "path": "{{ artifact.path }}",
    "sha256": "{{ artifact.sha256 }}",
    "size_bytes": "{{ artifact.size_bytes }}"
  },
  "context_delta": {
    "token_budget": 4000,
    "tokens_used": "{{ context_delta.tokens_used }}",
    "input_handles": [
      "{{ context_delta.input_handles[0] }}",
      "{{ context_delta.input_handles[1] }}",
      "{{ context_delta.input_handles[2] }}"
    ],
    "summary": "{{ context_delta.summary }}"
  },
  "constraints": {
    "trust_level": "{{ constraints.trust_level }}"
  },
  "expected_response": {
    "performative": "ACKNOWLEDGE",
    "shape_hint": "envelope-only (artifact.size_bytes <= 256)"
  },
  "confidence": "{{ confidence }}",
  "assumptions": [
    "{{ assumptions[0] }}"
  ],
  "integrity": {
    "method": "sha256",
    "value": "{{ integrity.value }}"
  },
  "trace": {
    "ts": "{{ trace.ts }}",
    "host": "{{ trace.host }}",
    "model": "{{ trace.model }}",
    "tier": "standard"
  }
}
